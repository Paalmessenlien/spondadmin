# Production Environment Configuration
# Copy to .env and fill in values

# === Application ===
PROJECT_NAME=Spond Admin API
CLUB_NAME=Lillehammer Bueskyttere
API_V1_PREFIX=/api/v1
DEBUG=false
# pydantic-settings parses List[str] as JSON — use a JSON array, not comma-separated.
ALLOWED_ORIGINS=["https://admin.lillehammerbueskyttere.no"]

# === Database (PostgreSQL) ===
POSTGRES_DB=spond_admin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/spond_admin

# === Security ===
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Spond API ===
SPOND_USERNAME=your-spond-email@example.com
SPOND_PASSWORD=your-spond-password

# === Sync Settings ===
AUTO_SYNC_ENABLED=true
SYNC_EVENTS_ENABLED=true
SYNC_EVENTS_INTERVAL_MINUTES=60
SYNC_EVENTS_MAX_EVENTS=500
SYNC_GROUPS_ENABLED=true
SYNC_GROUPS_INTERVAL_MINUTES=360
SYNC_MEMBERS_ENABLED=true
SYNC_MEMBERS_INTERVAL_MINUTES=360

# === Bunny CDN (Backup Storage) ===
BUNNY_STORAGE_ZONE=archery-trainer-storage
BUNNY_STORAGE_API_KEY=CHANGE_ME
BUNNY_CDN_HOSTNAME=archery-trainer-storage.b-cdn.net
BUNNY_STORAGE_REGION=

# === Bueskyting.no Scraper ===
BUESKYTING_BASE_URL=https://resultat.bueskyting.no
BUESKYTING_RECORDS_URL=https://rekord.bueskyting.no
BUESKYTING_CLUB_ID=
