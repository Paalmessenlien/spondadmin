# Production Environment Configuration
# Copy to .env and fill in values

# === Application ===
PROJECT_NAME=Spond Admin API
CLUB_NAME=Lillehammer Bueskyttere
API_V1_PREFIX=/api/v1
DEBUG=false
# pydantic-settings parses List[str] as JSON — use a JSON array, not comma-separated.
ALLOWED_ORIGINS=["https://admin.lillehammerbueskyttere.no"]

# === Database (PostgreSQL) ===
POSTGRES_DB=spond_admin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/spond_admin

# === Security ===
# Generate with: openssl rand -hex 32
# Used by app/core/encryption.py to derive a Fernet key for AI-provider
# secrets at rest. (No longer used for JWT signing — Clerk owns sessions.)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# === Clerk Auth ===
# These come from your *production* Clerk application (pk_live_*, sk_live_*).
# The publishable key encodes the Clerk frontend hostname; the issuer below
# must point at that same hostname (custom domain when configured).
# Backend:
CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_ISSUER=https://clerk.lillehammerbueskyttere.no
CLERK_AUTHORIZED_PARTIES=["https://admin.lillehammerbueskyttere.no"]
# Frontend (Nuxt build-time + SSR). Publishable key must equal CLERK_PUBLISHABLE_KEY above.
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
NUXT_CLERK_SECRET_KEY=sk_live_CHANGE_ME

# === First Admin Bootstrap ===
# Filled in by deploy.sh on first deploy. Idempotent: re-runs are safe.
# Set BOOTSTRAP_ADMIN_EMAIL to enable; leave empty to skip the step.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_FULL_NAME=
BOOTSTRAP_ADMIN_ROLE=admin

# === Spond API ===
SPOND_USERNAME=your-spond-email@example.com
SPOND_PASSWORD=your-spond-password

# === Sync Settings ===
AUTO_SYNC_ENABLED=true
SYNC_EVENTS_ENABLED=true
SYNC_EVENTS_INTERVAL_MINUTES=60
SYNC_EVENTS_MAX_EVENTS=500
SYNC_GROUPS_ENABLED=true
SYNC_GROUPS_INTERVAL_MINUTES=360
SYNC_MEMBERS_ENABLED=true
SYNC_MEMBERS_INTERVAL_MINUTES=360

# === Bunny CDN (Backup Storage) ===
BUNNY_STORAGE_ZONE=archery-trainer-storage
BUNNY_STORAGE_API_KEY=CHANGE_ME
BUNNY_CDN_HOSTNAME=archery-trainer-storage.b-cdn.net
BUNNY_STORAGE_REGION=

# === Bueskyting.no Scraper ===
BUESKYTING_BASE_URL=https://resultat.bueskyting.no
BUESKYTING_RECORDS_URL=https://rekord.bueskyting.no
BUESKYTING_CLUB_ID=
