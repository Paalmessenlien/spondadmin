# Copy this file to `.env.docker.local` (untracked) and fill in real values.
# docker-compose.yml loads it after `.env.docker`, so these override the blanks there.
# Do NOT commit `.env.docker.local`.

# Clerk dev instance (from your local Clerk application)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=

# Spond API login used for sync
SPOND_USERNAME=
SPOND_PASSWORD=
